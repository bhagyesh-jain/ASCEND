@model DashboardVM
@{
    ViewData["Title"] = "Dashboard";
}

<div style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 2.5rem; align-items: start;">
    <!-- LEFT COLUMN: Status & Quests -->
    <div style="display: flex; flex-direction: column; gap: 2.5rem;">
        
        <!-- RPG Character Status Card -->
        <div class="glass-card status-window">
            <div class="status-header">
                <div class="status-title-group">
                    <span style="font-size: 0.75rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700;">Hunter Profile</span>
                    <h2 class="neon-text" style="margin-top: 2px;">@Model.User.Username</h2>
                </div>
                <div class="rank-badge">@Model.User.Rank</div>
            </div>

            <div class="status-grid">
                <div class="status-item">
                    <span class="status-label">Equipped Title</span>
                    <span class="status-value accent" style="font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; letter-spacing: 0.5px;">
                        [@Model.User.EquippedTitle]
                    </span>
                </div>
                <div class="status-item">
                    <span class="status-label">Current Level</span>
                    <span class="status-value user-level-value" style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: var(--color-primary);">
                        @Model.User.Level
                    </span>
                </div>
                <div class="status-item">
                    <span class="status-label">Current Streak</span>
                    <span class="status-value" style="display: flex; align-items: center; gap: 8px;">
                        <i class="fa-solid fa-fire" style="color: #FF5722; filter: drop-shadow(0 0 5px rgba(255,87,34,0.5));"></i>
                        <span class="streak-value">@Model.User.CurrentStreak</span> Days
                    </span>
                </div>
                <div class="status-item">
                    <span class="status-label">Longest Streak</span>
                    <span class="status-value">
                        @Model.User.LongestStreak Days
                    </span>
                </div>
            </div>

            <!-- XP Progress Bar -->
            <div class="xp-section">
                <div class="xp-labels">
                    <span>XP PROGRESS</span>
                    <span class="xp-text-value">@Model.User.XP / @Model.XPNeededForNextLevel XP</span>
                </div>
                <div class="xp-bar-container">
                    <div class="xp-bar-fill" style="width: @(Model.XPPercentage)%;" data-next-threshold="@Model.XPNeededForNextLevel"></div>
                </div>
            </div>
        </div>

        <!-- Today's Quests (Habits) -->
        <div>
            <div class="quest-section-header">
                <span><i class="fa-solid fa-journal-whills" style="color: var(--color-primary); margin-right: 10px;"></i>Today's Quests</span>
                <a asp-controller="Habits" asp-action="Create" class="btn-premium" style="font-size: 0.8rem; padding: 0.5rem 1rem;">
                    <i class="fa-solid fa-plus"></i> New Quest
                </a>
            </div>

            <div class="quest-list">
                @if (Model.HabitsToday.Count == 0)
                {
                    <div class="glass-card" style="text-align: center; padding: 3rem 1.5rem; color: var(--text-secondary);">
                        <i class="fa-solid fa-circle-question" style="font-size: 3rem; color: var(--border-glass-hover); margin-bottom: 1rem;"></i>
                        <p style="font-weight: 500;">No active quests found for today.</p>
                        <p style="font-size: 0.85rem; margin-top: 0.5rem;">Go to the <a asp-controller="Habits" asp-action="Index" style="color: var(--color-primary); font-weight: 600; text-decoration: none;">Quests page</a> to awaken your daily habits!</p>
                    </div>
                }
                else
                {
                    <!-- Anti-Forgery Token for AJAX requests -->
                    @Html.AntiForgeryToken()

                    @foreach (var quest in Model.HabitsToday)
                    {
                        var categoryIcon = quest.Category.ToLower() switch
                        {
                            "study" => "fa-book",
                            "exercise" => "fa-dumbbell",
                            "reading" => "fa-book-open",
                            "meditation" => "fa-spa",
                            "coding" => "fa-code",
                            "water" => "fa-glass-water",
                            _ => quest.Icon
                        };

                        <div class="quest-item @(quest.CompletedToday ? "completed" : "")" data-habit-id="@quest.HabitId">
                            <div class="quest-left">
                                <label class="quest-checkbox-wrapper">
                                    <input type="checkbox" class="quest-checkbox" data-habit-id="@quest.HabitId" checked="@quest.CompletedToday" />
                                    <span class="quest-checkmark">
                                        <i class="fa-solid fa-check"></i>
                                    </span>
                                </label>
                                <div class="quest-info">
                                    <span class="quest-name">@quest.Name</span>
                                    <div class="quest-meta">
                                        <span class="quest-category-badge" style="color: @quest.Color; border: 1px solid @(quest.Color)33; background: @(quest.Color)0d;">
                                            <i class="fa-solid @categoryIcon" style="margin-right: 5px;"></i>@quest.Category
                                        </span>
                                        <span class="quest-difficulty">
                                            Rank: @quest.Difficulty
                                        </span>
                                    </div>
                                </div>
                            </div>
                            <div class="quest-right">
                                <span class="quest-xp-reward" style="color: @quest.Color; border-color: @(quest.Color)33; background: @(quest.Color)0d;">
                                    +@quest.XPReward XP
                                </span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

    </div>

    <!-- RIGHT COLUMN: Quick Stats & Achievements -->
    <div style="display: flex; flex-direction: column; gap: 2.5rem;">
        
        <!-- Quick Statistics -->
        <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-chart-simple" style="color: var(--color-primary); margin-right: 10px;"></i>Quick Statistics
            </h3>
            
            <div style="display: flex; flex-direction: column; gap: 1.25rem;">
                <!-- Completion Rate -->
                <div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">
                        <span>TODAY'S COMPLETION RATE</span>
                        <span style="color: var(--color-primary);">@Model.CompletionRate%</span>
                    </div>
                    <div class="xp-bar-container" style="height: 8px;">
                        <div class="xp-bar-fill" style="width: @(Model.CompletionRate)%; background: var(--color-primary);"></div>
                    </div>
                </div>

                <!-- Weekly Progress -->
                <div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">
                        <span>WEEKLY PROGRESS</span>
                        <span style="color: var(--color-secondary);">@Model.WeeklyProgress%</span>
                    </div>
                    <div class="xp-bar-container" style="height: 8px;">
                        <div class="xp-bar-fill" style="width: @(Model.WeeklyProgress)%; background: var(--color-secondary);"></div>
                    </div>
                </div>

                <!-- Monthly Progress -->
                <div>
                    <div style="display: flex; justify-content: space-between; font-size: 0.85rem; font-weight: 600; margin-bottom: 6px;">
                        <span>MONTHLY PROGRESS</span>
                        <span style="color: var(--color-accent);">@Model.MonthlyProgress%</span>
                    </div>
                    <div class="xp-bar-container" style="height: 8px;">
                        <div class="xp-bar-fill" style="width: @(Model.MonthlyProgress)%; background: var(--color-accent);"></div>
                    </div>
                </div>

                <!-- Achievements Count -->
                <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 1rem; border-top: 1px solid var(--border-glass); margin-top: 0.5rem;">
                    <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">ACHIEVEMENTS UNLOCKED</span>
                    <span style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: var(--color-accent); text-shadow: 0 0 10px var(--glow-secondary);">
                        @Model.AchievementsCount
                    </span>
                </div>
            </div>
        </div>

        <!-- Recent Achievements -->
        <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-trophy" style="color: var(--color-primary); margin-right: 10px;"></i>Recent Achievements
            </h3>

            <div style="display: flex; flex-direction: column; gap: 1rem;">
                @if (Model.RecentAchievements.Count == 0)
                {
                    <p style="text-align: center; color: var(--text-secondary); font-size: 0.85rem; padding: 1.5rem 0;">
                        No achievements unlocked yet. Continue your quests to earn medals!
                    </p>
                }
                else
                {
                    foreach (var ach in Model.RecentAchievements)
                    {
                        <div style="display: flex; align-items: flex-start; gap: 12px; padding: 0.75rem; border-radius: 12px; background: rgba(255, 255, 255, 0.02); border: 1px solid var(--border-glass);">
                            <div style="width: 32px; height: 32px; border-radius: 50%; background: rgba(255, 215, 0, 0.1); border: 1px solid #FFD700; display: flex; align-items: center; justify-content: center; color: #FFD700; flex-shrink: 0; filter: drop-shadow(0 0 4px rgba(255,215,0,0.3));">
                                <i class="fa-solid fa-medal" style="font-size: 0.95rem;"></i>
                            </div>
                            <div style="display: flex; flex-direction: column; overflow: hidden;">
                                <span style="font-weight: 600; font-size: 0.95rem; color: var(--text-primary);">@ach.Title</span>
                                <span style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 2px;">@ach.Description</span>
                            </div>
                        </div>
                    }
                }
            </div>
            
            <div style="text-align: center; margin-top: 1.5rem;">
                <a asp-controller="Profile" asp-action="Index" style="color: var(--color-primary); font-size: 0.85rem; font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;">
                    View All Achievements <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>

    </div>
</div>

@model StatsVM
@{
    ViewData["Title"] = "Statistics";
}

<!-- Title -->
<div style="margin-bottom: 2.5rem;">
    <h1 style="font-family: var(--font-display); font-size: 2.2rem; font-weight: 900; letter-spacing: 1px;">
        <i class="fa-solid fa-chart-line" style="color: var(--color-primary); margin-right: 10px;"></i>Hunter Analytics
    </h1>
    <p style="color: var(--text-secondary); margin-top: 4px;">Track your growth metrics, view quest completion consistency, and review historical performance.</p>
</div>

<!-- Stats Cards Grid -->
<div class="stats-summary-grid">
    <div class="glass-card" style="text-align: center;">
        <span class="status-label">Current Streak</span>
        <div class="stats-card-value" style="color: #FF5722; text-shadow: 0 0 15px rgba(255,87,34,0.4); display: flex; align-items: center; justify-content: center; gap: 8px;">
            <i class="fa-solid fa-fire"></i>
            <span>@Model.CurrentStreak</span>
        </div>
        <span style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 500;">Active Consecutive Days</span>
    </div>

    <div class="glass-card" style="text-align: center;">
        <span class="status-label">Longest Streak</span>
        <div class="stats-card-value" style="color: var(--color-accent);">
            @Model.LongestStreak
        </div>
        <span style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 500;">All-Time Record</span>
    </div>

    <div class="glass-card" style="text-align: center;">
        <span class="status-label">30-Day Completion Rate</span>
        <div class="stats-card-value" style="color: var(--color-primary);">
            @Model.CompletionRate%
        </div>
        <span style="font-size: 0.8rem; color: var(--text-secondary); font-weight: 500;">Quest Success Consistency</span>
    </div>
</div>

<!-- GitHub-style Heatmap Calendar -->
<div class="glass-card" style="margin-bottom: 2.5rem; overflow: hidden;">
    <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem; margin-bottom: 1.5rem;">
        <i class="fa-solid fa-calendar-days" style="color: var(--color-primary); margin-right: 10px;"></i>Quest Completion Heatmap
    </h3>
    
    <div class="heatmap-container">
        <!-- Rendered dynamically by JavaScript in the footer -->
        <div id="heatmap-grid" class="heatmap-grid"></div>
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; color: var(--text-secondary); margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--border-glass);">
        <span>Showing logs for the past 365 days</span>
        <div style="display: flex; align-items: center; gap: 6px;">
            <span>Less</span>
            <div class="heatmap-cell" style="cursor: default;"></div>
            <div class="heatmap-cell level-1" style="cursor: default;"></div>
            <div class="heatmap-cell level-2" style="cursor: default;"></div>
            <div class="heatmap-cell level-3" style="cursor: default;"></div>
            <div class="heatmap-cell level-4" style="cursor: default;"></div>
            <span>More</span>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem; align-items: start; margin-bottom: 2.5rem;">
    <!-- Weekly completions -->
    <div class="glass-card">
        <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem; margin-bottom: 1.5rem;">
            <i class="fa-solid fa-chart-simple" style="color: var(--color-primary); margin-right: 10px;"></i>Weekly Performance
        </h3>
        <div style="position: relative; height: 260px; width: 100%;">
            <canvas id="weeklyChart"></canvas>
        </div>
    </div>

    <!-- Category Breakdown -->
    <div class="glass-card">
        <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1rem; margin-bottom: 1.5rem;">
            <i class="fa-solid fa-pie-chart" style="color: var(--color-primary); margin-right: 10px;"></i>Category Distribution
        </h3>
        <div style="position: relative; height: 260px; width: 100%;">
            <canvas id="categoryChart"></canvas>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // ==========================================
            // 1. GENERATE HEATMAP CALENDAR
            // ==========================================
            const heatmapData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.HeatmapCompletions));
            const gridContainer = document.getElementById('heatmap-grid');
            
            if (gridContainer) {
                const today = new Date();
                const startDate = new Date();
                startDate.setDate(today.getDate() - 364); // Last 365 days
                
                // Adjust start date to previous Sunday so the grid rows align correctly
                const startDay = startDate.getDay();
                startDate.setDate(startDate.getDate() - startDay);
                
                const msInDay = 24 * 60 * 60 * 1000;
                const totalDays = Math.ceil((today.getTime() - startDate.getTime()) / msInDay) + 1;
                
                const fragment = document.createDocumentFragment();
                
                for (let i = 0; i < totalDays; i++) {
                    const currentDate = new Date(startDate.getTime() + i * msInDay);
                    const dateStr = currentDate.toISOString().split('T')[0];
                    const count = heatmapData[dateStr] || 0;
                    
                    const cell = document.createElement('div');
                    cell.className = 'heatmap-cell';
                    
                    // Assign intensity levels
                    if (count > 0) {
                        if (count === 1) cell.classList.add('level-1');
                        else if (count === 2) cell.classList.add('level-2');
                        else if (count === 3) cell.classList.add('level-3');
                        else cell.classList.add('level-4');
                    }
                    
                    // Format date for tooltip
                    const options = { month: 'short', day: 'numeric', year: 'numeric' };
                    const formattedDate = currentDate.toLocaleDateString('en-US', options);
                    cell.setAttribute('data-tooltip', `${count} completion${count !== 1 ? 's' : ''} on ${formattedDate}`);
                    
                    fragment.appendChild(cell);
                }
                
                gridContainer.appendChild(fragment);
            }

            // ==========================================
            // 2. RENDER CHART.JS CHARTS
            // ==========================================
            
            // Helper to extract CSS variable colors from active theme
            function getThemeColors() {
                const style = getComputedStyle(document.body);
                return {
                    primary: style.getPropertyValue('--color-primary').trim() || '#00CFFF',
                    secondary: style.getPropertyValue('--color-secondary').trim() || '#6A5ACD',
                    text: style.getPropertyValue('--text-primary').trim() || '#FFF',
                    muted: style.getPropertyValue('--text-secondary').trim() || '#94A3B8',
                    border: style.getPropertyValue('--border-glass').trim() || 'rgba(255, 255, 255, 0.08)'
                };
            }
            
            let colors = getThemeColors();

            // Weekly Chart (Bar)
            const weeklyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyAnalytics));
            const weeklyCtx = document.getElementById('weeklyChart').getContext('2d');
            
            const weeklyChart = new Chart(weeklyCtx, {
                type: 'bar',
                data: {
                    labels: Object.keys(weeklyData),
                    datasets: [{
                        label: 'Completions',
                        data: Object.values(weeklyData),
                        backgroundColor: colors.primary + '80', // 50% opacity
                        borderColor: colors.primary,
                        borderWidth: 2,
                        borderRadius: 6,
                        hoverBackgroundColor: colors.primary
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            grid: { color: colors.border },
                            ticks: { color: colors.muted, stepSize: 1 }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: colors.muted }
                        }
                    }
                }
            });

            // Category Chart (Doughnut)
            const categoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryStatistics));
            const categoryCtx = document.getElementById('categoryChart').getContext('2d');
            
            const categoryChart = new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(categoryData),
                    datasets: [{
                        data: Object.values(categoryData),
                        backgroundColor: [
                            colors.primary,
                            colors.secondary,
                            '#FFD700', // Gold
                            '#FF7EB6', // Pink
                            '#4CAF50', // Green
                            '#FF5722', // Orange
                            '#00E676'  // Light Green
                        ],
                        borderWidth: 1,
                        borderColor: 'rgba(0,0,0,0.3)'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'right',
                            labels: { color: colors.muted }
                        }
                    }
                }
            });

            // Update chart colors on theme change
            const observer = new MutationObserver(() => {
                colors = getThemeColors();
                
                // Update weekly chart
                weeklyChart.data.datasets[0].backgroundColor = colors.primary + '80';
                weeklyChart.data.datasets[0].borderColor = colors.primary;
                weeklyChart.options.scales.y.grid.color = colors.border;
                weeklyChart.options.scales.y.ticks.color = colors.muted;
                weeklyChart.options.scales.x.ticks.color = colors.muted;
                weeklyChart.update();

                // Update category chart
                categoryChart.options.plugins.legend.labels.color = colors.muted;
                categoryChart.update();
            });
            observer.observe(document.body, { attributes: true });
        });
    </script>
}

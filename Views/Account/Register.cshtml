@model RegisterVM
@{
    Layout = "_Layout";
    ViewData["Title"] = "Register";
}

<div class="glass-card" style="width: 100%; max-width: 440px; padding: 2.5rem; border-radius: 24px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
    <div style="text-align: center; margin-bottom: 2rem;">
        <h1 style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; letter-spacing: 2px; color: var(--text-primary); margin-bottom: 0.5rem;">
            <i class="fa-solid fa-angles-up" style="color: var(--color-primary); filter: drop-shadow(0 0 8px var(--glow-color)); margin-right: 8px;"></i>ASCEND
        </h1>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">"One App. Many Worlds. Endless Growth."</p>
    </div>

    <form asp-action="Register" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1rem; list-style-type: none; padding: 0;"></div>

        <div class="form-group">
            <label asp-for="Username" class="form-label">Hunter Username</label>
            <input asp-for="Username" class="form-input" placeholder="Choose your username" autocomplete="username" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email" class="form-label">Email Address</label>
            <input asp-for="Email" type="email" class="form-input" placeholder="you@example.com" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-input" placeholder="Min. 6 characters" autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" class="form-input" placeholder="Repeat password" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-premium" style="width: 100%; justify-content: center; padding: 0.9rem; margin-top: 0.5rem;">
            <i class="fa-solid fa-user-plus"></i> Awaken Hunter
        </button>
    </form>

    <div style="text-align: center; margin-top: 2rem; font-size: 0.85rem; color: var(--text-secondary);">
        Already registered? <a asp-action="Login" style="color: var(--color-primary); text-decoration: none; font-weight: 600;">Sign In here</a>
    </div>
</div>

@model LoginVM
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="glass-card" style="width: 100%; max-width: 420px; padding: 2.5rem; border-radius: 24px; box-shadow: 0 15px 35px rgba(0,0,0,0.4);">
    <div style="text-align: center; margin-bottom: 2rem;">
        <h1 style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 900; letter-spacing: 2px; color: var(--text-primary); margin-bottom: 0.5rem;">
            <i class="fa-solid fa-angles-up" style="color: var(--color-primary); filter: drop-shadow(0 0 8px var(--glow-color)); margin-right: 8px;"></i>ASCEND
        </h1>
        <p style="color: var(--text-secondary); font-size: 0.9rem;">"One App. Many Worlds. Endless Growth."</p>
    </div>

    <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
        @Html.AntiForgeryToken()
        
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 1rem; list-style-type: none; padding: 0;"></div>

        <div class="form-group">
            <label asp-for="Username" class="form-label">Hunter Username</label>
            <input asp-for="Username" class="form-input" placeholder="Enter your username" autocomplete="username" />
            <span asp-validation-for="Username" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password" class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-input" placeholder="••••••••" autocomplete="current-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; font-size: 0.85rem;">
            <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input asp-for="RememberMe" type="checkbox" style="accent-color: var(--color-primary);" /> Remember Me
            </label>
        </div>

        <button type="submit" class="btn-premium" style="width: 100%; justify-content: center; padding: 0.9rem;">
            <i class="fa-solid fa-bolt"></i> Begin Hunt
        </button>
    </form>

    <div style="text-align: center; margin-top: 2rem; font-size: 0.85rem; color: var(--text-secondary);">
        New Hunter? <a asp-action="Register" style="color: var(--color-primary); text-decoration: none; font-weight: 600;">Create an Account</a>
    </div>
</div>

@model ProfileVM
@{
    ViewData["Title"] = "Profile & Settings";
}

<div style="margin-bottom: 2.5rem;">
    <h1 style="font-family: var(--font-display); font-size: 2.2rem; font-weight: 900; letter-spacing: 1px;">
        <i class="fa-solid fa-sliders" style="color: var(--color-primary); margin-right: 10px;"></i>Profile & Settings
    </h1>
    <p style="color: var(--text-secondary); margin-top: 4px;">Equip your earned titles, alter your theme world, toggle audio systems, and manage your account.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="glass-card" style="border-color: #4CAF50; background: rgba(76, 175, 80, 0.08); padding: 1rem 1.5rem; margin-bottom: 2.5rem; border-radius: 12px; display: flex; align-items: center; gap: 10px;">
        <i class="fa-solid fa-circle-check" style="color: #4CAF50; font-size: 1.2rem;"></i>
        <span style="color: #F1F8E9; font-weight: 500;">@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="glass-card" style="border-color: #EF4444; background: rgba(239, 68, 68, 0.08); padding: 1rem 1.5rem; margin-bottom: 2.5rem; border-radius: 12px; display: flex; align-items: center; gap: 10px;">
        <i class="fa-solid fa-triangle-exclamation" style="color: #EF4444; font-size: 1.2rem;"></i>
        <span style="color: #FEE2E2; font-weight: 500;">@TempData["ErrorMessage"]</span>
    </div>
}

<div style="display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 2.5rem; align-items: start; margin-bottom: 2.5rem;">
    
    <!-- LEFT COLUMN: Theme Switching & Title Equipping -->
    <div style="display: flex; flex-direction: column; gap: 2.5rem;">
        
        <!-- Theme Switching -->
        <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.25rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-globe" style="color: var(--color-primary); margin-right: 10px;"></i>Select Dimension Theme
            </h3>
            <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem;">Shifting your dimension instantly alters the background, colors, fonts, and particle systems across the application.</p>
            
            <!-- Anti-Forgery Token for AJAX -->
            @Html.AntiForgeryToken()

            <div class="theme-picker-grid">
                <!-- Theme 1: Shadow Hunter -->
                <div class="theme-card @(Model.SelectedTheme == "Shadow Hunter" ? "active" : "")" data-theme-name="Shadow Hunter">
                    <div class="theme-preview-palette">
                        <div class="theme-preview-color" style="background: #0B0F19;"></div>
                        <div class="theme-preview-color" style="background: #00CFFF;"></div>
                        <div class="theme-preview-color" style="background: #6A5ACD;"></div>
                    </div>
                    <span class="theme-card-title">Shadow Hunter</span>
                    <span class="theme-card-desc">Dark fantasy. Cyan neon particles, cybernetic RPG status windows.</span>
                </div>

                <!-- Theme 2: Sakura Ascension -->
                <div class="theme-card @(Model.SelectedTheme == "Sakura Ascension" ? "active" : "")" data-theme-name="Sakura Ascension">
                    <div class="theme-preview-palette">
                        <div class="theme-preview-color" style="background: #1A1025;"></div>
                        <div class="theme-preview-color" style="background: #FF7EB6;"></div>
                        <div class="theme-preview-color" style="background: #C084FC;"></div>
                    </div>
                    <span class="theme-card-title" style="font-family: 'Playfair Display', serif;">Sakura Ascension</span>
                    <span class="theme-card-desc">Elegant fantasy. Soft falling cherry blossoms, pink glassmorphism.</span>
                </div>

                <!-- Theme 3: Celestial Realm -->
                <div class="theme-card @(Model.SelectedTheme == "Celestial Realm" ? "active" : "")" data-theme-name="Celestial Realm">
                    <div class="theme-preview-palette">
                        <div class="theme-preview-color" style="background: #0D1B2A;"></div>
                        <div class="theme-preview-color" style="background: #E0AAFF;"></div>
                        <div class="theme-preview-color" style="background: #FFD6FF;"></div>
                    </div>
                    <span class="theme-card-title">Celestial Realm</span>
                    <span class="theme-card-desc">Cosmic fantasy. Twinkling starry nights and constellation achievements.</span>
                </div>

                <!-- Theme 4: Forest Guardian -->
                <div class="theme-card @(Model.SelectedTheme == "Forest Guardian" ? "active" : "")" data-theme-name="Forest Guardian">
                    <div class="theme-preview-palette">
                        <div class="theme-preview-color" style="background: #102A13;"></div>
                        <div class="theme-preview-color" style="background: #4CAF50;"></div>
                        <div class="theme-preview-color" style="background: #FFD700;"></div>
                    </div>
                    <span class="theme-card-title">Forest Guardian</span>
                    <span class="theme-card-desc">Nature fantasy. Drifting magical forest leaves and gold accents.</span>
                </div>
            </div>
        </div>

        <!-- Title Room -->
        <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.25rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-crown" style="color: var(--color-primary); margin-right: 10px;"></i>Title Equip Chamber
            </h3>

            <form asp-action="UpdateTitle" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label class="form-label">Equip Active Title</label>
                    <select name="title" class="form-input" style="cursor: pointer; margin-bottom: 1.25rem;">
                        @foreach (var t in Model.AvailableTitles)
                        {
                            if (t.IsUnlocked)
                            {
                                <!option value="@t.Title" @(Model.EquippedTitle == t.Title ? "selected" : "")>@t.Title (Unlocked)</!option>
                            }
                            else
                            {
                                <!option value="@t.Title" disabled>🔒 @t.Title (Requires: @t.UnlockRequirement)</!option>
                            }
                        }
                    </select>
                </div>
                <button type="submit" class="btn-premium">
                    <i class="fa-solid fa-shield-halved"></i> Equip Title
                </button>
            </form>
        </div>

    </div>

    <!-- RIGHT COLUMN: User Profile & Sound Settings -->
    <div style="display: flex; flex-direction: column; gap: 2.5rem;">
        
        <!-- Profile details -->
        <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.25rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-user-gear" style="color: var(--color-primary); margin-right: 10px;"></i>Hunter Profile Details
            </h3>

            <form asp-action="UpdateProfile" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label asp-for="Username" class="form-label">Username</label>
                    <input asp-for="Username" class="form-input" />
                </div>
                <div class="form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <input asp-for="Email" type="email" class="form-input" />
                </div>
                <button type="submit" class="btn-premium">
                    <i class="fa-solid fa-floppy-disk"></i> Update Profile
                </button>
            </form>
        </div>

        <!-- Change Password -->
        <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.25rem; margin-bottom: 1.5rem;">
                <i class="fa-solid fa-key" style="color: var(--color-primary); margin-right: 10px;"></i>Change Password
            </h3>

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                    <input asp-for="CurrentPassword" type="password" class="form-input" placeholder="••••••••" required />
                </div>
                <div class="form-group">
                    <label asp-for="NewPassword" class="form-label">New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-input" placeholder="••••••••" required />
                </div>
                <button type="submit" class="btn-premium" style="background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border-glass); color: var(--text-primary); box-shadow: none;">
                    <i class="fa-solid fa-lock-open"></i> Reset Password
                </button>
            </form>
        </div>

        <!-- Sound Settings -->
        <div class="glass-card">
            <h3 style="font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.25rem; margin-bottom: 1rem;">
                <i class="fa-solid fa-volume-high" style="color: var(--color-primary); margin-right: 10px;"></i>Acoustic Systems
            </h3>
            <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0;">
                <span style="font-size: 0.9rem; color: var(--text-secondary);">Enable RPG synthesizer sounds (level-up, quest complete)</span>
                <label style="position: relative; display: inline-block; width: 44px; height: 24px; cursor: pointer;">
                    <input type="checkbox" id="sound-settings-toggle" style="opacity: 0; width: 0; height: 0;" />
                    <span style="position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: rgba(255,255,255,0.1); transition: .4s; border-radius: 24px; border: 1px solid var(--border-glass);" class="slider"></span>
                </label>
            </div>
        </div>

    </div>
</div>

<!-- BOTTOM SECTION: Achievements Vault -->
<div class="glass-card" style="margin-bottom: 2.5rem;">
    <h3 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; border-bottom: 1px solid var(--border-glass); padding-bottom: 1.25rem; margin-bottom: 2rem;">
        <i class="fa-solid fa-award" style="color: var(--color-primary); margin-right: 12px; filter: drop-shadow(0 0 5px var(--glow-color));"></i>Achievements Vault
    </h3>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem;">
        @foreach (var ach in Model.Achievements)
        {
            <div class="glass-card" style="padding: 1.5rem; border-radius: 16px; border: 1.5px solid @(ach.IsUnlocked ? "var(--color-primary)" : "var(--border-glass)"); background: @(ach.IsUnlocked ? "var(--card-gradient)" : "rgba(255,255,255,0.01)"); display: flex; align-items: flex-start; gap: 15px; opacity: @(ach.IsUnlocked ? "1" : "0.5"); box-shadow: @(ach.IsUnlocked ? "var(--glow-shadow)" : "none");">
                <div style="width: 42px; height: 42px; border-radius: 50%; background: @(ach.IsUnlocked ? "rgba(255, 215, 0, 0.15)" : "rgba(255,255,255,0.03)"); border: 1.5px solid @(ach.IsUnlocked ? "#FFD700" : "var(--border-glass)"); display: flex; align-items: center; justify-content: center; color: @(ach.IsUnlocked ? "#FFD700" : "var(--text-secondary)"); flex-shrink: 0; filter: @(ach.IsUnlocked ? "drop-shadow(0 0 6px rgba(255,215,0,0.4))" : "none");">
                    <i class="fa-solid fa-trophy" style="font-size: 1.2rem;"></i>
                </div>
                <div style="display: flex; flex-direction: column;">
                    <span style="font-weight: 700; font-size: 1.1rem; color: var(--text-primary);">@ach.Title</span>
                    <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 4px; line-height: 1.4;">@ach.Description</span>
                    @if (ach.IsUnlocked)
                    {
                        <span style="font-size: 0.7rem; color: var(--color-primary); font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 8px;">
                            Unlocked: @ach.UnlockDate
                        </span>
                    }
                    else
                    {
                        <span style="font-size: 0.7rem; color: var(--text-secondary); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 8px;">
                            Locked
                        </span>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <style>
        /* Custom styling for switch slider */
        input:checked + .slider {
            background-color: var(--color-primary);
            box-shadow: var(--glow-shadow);
            border-color: var(--color-primary);
        }
        .slider:before {
            position: absolute;
            content: "";
            height: 16px;
            width: 16px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        input:checked + .slider:before {
            transform: translateX(20px);
        }
    </style>
}

@model IEnumerable<ASCEND.Models.Habit>
@{
    ViewData["Title"] = "Quests";
    var currentSearch = ViewData["CurrentSearch"] as string;
    var currentCategory = ViewData["CurrentCategory"] as string ?? "All";
    var currentSort = ViewData["CurrentSort"] as string ?? "Name_Asc";
}

<div style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.25rem;">
    <div>
        <h1 style="font-family: var(--font-display); font-size: 2.2rem; font-weight: 900; letter-spacing: 1px;">
            <i class="fa-solid fa-scroll" style="color: var(--color-primary); margin-right: 10px; filter: drop-shadow(0 0 5px var(--glow-color));"></i>Active Quest Log
        </h1>
        <p style="color: var(--text-secondary); margin-top: 4px;">Awaken, track, and customize your daily habits and self-improvement goals.</p>
    </div>
    <a asp-action="Create" class="btn-premium">
        <i class="fa-solid fa-wand-magic-sparkles"></i> Awaken New Quest
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="glass-card" style="border-color: #10B981; background: rgba(16, 185, 129, 0.08); padding: 1rem 1.5rem; margin-bottom: 2rem; border-radius: 14px; display: flex; align-items: center; gap: 10px;">
        <i class="fa-solid fa-circle-check" style="color: #10B981; font-size: 1.2rem;"></i>
        <span style="color: #ECFDF5; font-weight: 600; font-size: 0.95rem;">@TempData["SuccessMessage"]</span>
    </div>
}

<!-- Search & Filtering Bar -->
<div class="glass-card" style="padding: 1.5rem; margin-bottom: 2.5rem; border-radius: 20px;">
    <form asp-action="Index" method="get" class="filter-form">
        
        <!-- Search Input -->
        <div style="position: relative;">
            <input type="text" name="search" value="@currentSearch" class="form-input" placeholder="Search active quests..." style="padding-left: 2.75rem;" />
            <i class="fa-solid fa-magnifying-glass" style="position: absolute; left: 1.15rem; top: 50%; transform: translateY(-50%); color: var(--text-secondary); font-size: 0.95rem;"></i>
        </div>

        <!-- Category Filter -->
        <div>
            <select name="category" class="form-input" style="cursor: pointer;">
                <!option value="All" @(currentCategory == "All" ? "selected" : "")>All Categories</!option>
                <!option value="Study" @(currentCategory == "Study" ? "selected" : "")>Study</!option>
                <!option value="Exercise" @(currentCategory == "Exercise" ? "selected" : "")>Exercise</!option>
                <!option value="Reading" @(currentCategory == "Reading" ? "selected" : "")>Reading</!option>
                <!option value="Meditation" @(currentCategory == "Meditation" ? "selected" : "")>Meditation</!option>
                <!option value="Coding" @(currentCategory == "Coding" ? "selected" : "")>Coding</!option>
                <!option value="Water" @(currentCategory == "Water" ? "selected" : "")>Water Intake</!option>
                <!option value="Custom" @(currentCategory == "Custom" ? "selected" : "")>Custom</!option>
            </select>
        </div>

        <!-- Sort By -->
        <div>
            <select name="sortBy" class="form-input" style="cursor: pointer;">
                <!option value="Name_Asc" @(currentSort == "Name_Asc" ? "selected" : "")>Sort: Name A-Z</!option>
                <!option value="Name_Desc" @(currentSort == "Name_Desc" ? "selected" : "")>Sort: Name Z-A</!option>
                <!option value="XP_Desc" @(currentSort == "XP_Desc" ? "selected" : "")>Sort: XP High-Low</!option>
                <!option value="XP_Asc" @(currentSort == "XP_Asc" ? "selected" : "")>Sort: XP Low-High</!option>
                <!option value="Difficulty" @(currentSort == "Difficulty" ? "selected" : "")>Sort: Quest Rank</!option>
            </select>
        </div>

        <!-- Action Buttons -->
        <div>
            <button type="submit" class="btn-premium" style="width: 100%; padding: 0.85rem; border-radius: 12px; font-size: 0.8rem;">
                <i class="fa-solid fa-filter"></i> Apply Filter
            </button>
        </div>
    </form>
</div>

<!-- Quests Grid -->
<div class="quests-grid">
    @if (!Model.Any())
    {
        <div class="glass-card" style="grid-column: 1 / -1; text-align: center; padding: 5rem 2rem; color: var(--text-secondary); border-radius: 20px;">
            <i class="fa-solid fa-scroll" style="font-size: 4rem; color: var(--border-glass); margin-bottom: 1.5rem; opacity: 0.5;"></i>
            <h3 style="color: var(--text-primary); font-weight: 800; font-size: 1.25rem;">No Active Quests Found</h3>
            <p style="font-size: 0.9rem; margin-top: 0.5rem; max-width: 400px; margin-left: auto; margin-right: auto; line-height: 1.5;">Awaken your potential by creating your first daily quest. Tap the button above to begin.</p>
        </div>
    }
    else
    {
        foreach (var habit in Model)
        {
            var categoryIcon = habit.Category.ToLower() switch
            {
                "study" => "fa-book",
                "exercise" => "fa-dumbbell",
                "reading" => "fa-book-open",
                "meditation" => "fa-spa",
                "coding" => "fa-code",
                "water" => "fa-glass-water",
                _ => habit.Icon
            };

            <div class="glass-card" style="display: flex; flex-direction: column; justify-content: space-between; border-left: 4.5px solid @habit.Color; min-height: 220px; border-radius: 20px; box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);">
                <div>
                    <!-- Quest Header -->
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.15rem; gap: 8px;">
                        <span class="quest-category-badge" style="color: @habit.Color; border: 1.5px solid @(habit.Color)33; background: @(habit.Color)0d;">
                            <i class="fa-solid @categoryIcon" style="margin-right: 5px;"></i>@habit.Category
                        </span>
                        <span class="quest-xp-reward" style="color: @habit.Color; border: 1.5px solid @(habit.Color)33; background: @(habit.Color)0d; font-size: 0.8rem; padding: 0.25rem 0.55rem; font-family: var(--font-display); font-weight: 800;">
                            +@habit.XPReward XP
                        </span>
                    </div>

                    <!-- Quest Name -->
                    <h3 style="font-size: 1.25rem; font-weight: 800; color: var(--text-primary); margin-bottom: 0.65rem; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">@habit.Name</h3>
                    
                    <!-- Quest Details -->
                    <div style="display: flex; flex-direction: column; gap: 5px; font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
                        <span>Rank: <strong style="color: var(--text-primary); font-weight: 700;">@habit.Difficulty</strong></span>
                        @if (habit.ReminderTime.HasValue)
                        {
                            <span>Daily Reminder: <strong style="color: var(--text-primary); font-weight: 700;">@DateTime.Today.Add(habit.ReminderTime.Value).ToString("t")</strong></span>
                        }
                    </div>
                </div>

                <!-- Action Buttons -->
                <div style="display: flex; justify-content: flex-end; gap: 10px; border-top: 1px solid var(--border-glass); padding-top: 1rem; margin-top: auto;">
                    <a asp-action="Edit" asp-route-id="@habit.HabitId" class="btn-premium" style="background: rgba(255, 255, 255, 0.04); border: 1.5px solid var(--border-glass); color: var(--text-primary); box-shadow: none; font-size: 0.75rem; padding: 0.5rem 1rem; border-radius: 10px;">
                        <i class="fa-solid fa-pen-to-square"></i> Modify
                    </a>
                    <form asp-action="Delete" asp-route-id="@habit.HabitId" method="post" onsubmit="return confirm('Are you sure you want to abandon (delete) this quest?');" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-premium" style="background: rgba(239, 68, 68, 0.08); border: 1.5px solid rgba(239, 68, 68, 0.2); color: #F87171; box-shadow: none; font-size: 0.75rem; padding: 0.5rem 1rem; border-radius: 10px; font-family: var(--font-display);">
                            <i class="fa-solid fa-trash-can"></i> Abandon
                        </button>
                    </form>
                </div>
            </div>
        }
    }
</div>

@section Scripts {
    <style>
        .filter-form {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1.25fr;
            gap: 1.25rem;
            align-items: center;
        }

        .quests-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 2rem;
            margin-bottom: 3rem;
        }

        @@media (max-width: 992px) {
            .filter-form {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width: 576px) {
            .filter-form {
                grid-template-columns: 1fr;
            }
        }

    </style>
}
